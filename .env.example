# ─────────────────────────────────────────────────────────────────────────────
# Lumen — environment variables (documented; DO NOT put real secrets in this file)
# Copy to apps/web/.env.local and fill. Server-only vars (no NEXT_PUBLIC_) never
# reach the browser.
# ─────────────────────────────────────────────────────────────────────────────

# ── 0G Compute (server-only — the gateway holds this; never exposed to client) ──
# Create a key at https://pc.0g.ai and deposit a little 0G to fund inference.
# If ZG_COMPUTE_API_KEY is unset, Lumen runs in clearly-labeled DEMO mode
# (a mock TEE stream) so the loop is always clickable.
ZG_COMPUTE_API_KEY=
ZG_ROUTER_BASE_URL=https://router-api.0g.ai/v1
ZG_COMPUTE_MODEL=glm-5

# ── 0G Chain (client-safe) ──────────────────────────────────────────────────────
# Galileo testnet chainId is contested: docs.0g.ai / ChainList show 16602, while an
# official 0G relaunch post + ThirdWeb show 16601. CONFIRM via the wallet
# "Add Network" prompt before relying on it. Wave 1's wallet is a non-transacting stub.
NEXT_PUBLIC_ZG_NETWORK=testnet
NEXT_PUBLIC_ZG_CHAIN_ID=16602
NEXT_PUBLIC_ZG_RPC=https://evmrpc-testnet.0g.ai

# ── Wallet (client-safe) ────────────────────────────────────────────────────────
# WalletConnect Cloud project id (https://cloud.walletconnect.com). Optional in W1.
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=

# ── Contracts (filled after deploy — Wave 3) ────────────────────────────────────
NEXT_PUBLIC_LUMEN_INFT_ADDRESS=
NEXT_PUBLIC_LUMEN_REGISTRY_ADDRESS=
